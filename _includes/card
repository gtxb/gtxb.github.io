<div class="feature__item">
  <div class="archive__item">
     {% if include.image_path %}
      <div class="archive__item-teaser">
        <img src="{{ include.image_path | relative_url }}"
             alt="{% if include.alt %}{{ include.alt }}{% endif %}">
        {% if include.image_caption %}
          <span class="archive__item-caption">{{ include.image_caption | markdownify | remove: "<p>" | remove: "</p>" }}</span>
        {% endif %}
      </div>
    {% endif %}
    
    <div class="archive__item-body">
      {% if include.title %}
      <a href="{{ include.url | relative_url }}">
          <h2 class="archive__item-title">{{ include.title }}</h2>
      </a>
      {% endif %}
      {% if include.excerpt %}
        <div class="archive__item-excerpt">
          {{ include.excerpt | markdownify }}
        </div>
      {% endif %}
    </div>
  </div>
</div>

